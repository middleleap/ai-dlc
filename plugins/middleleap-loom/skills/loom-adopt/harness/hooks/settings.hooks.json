{
  "_comment": "Merge into the adopting repo's .claude/settings.json. Paths assume the hook scripts land in .claude/hooks/.",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit|NotebookEdit",
        "hooks": [
          { "type": "command", "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/pii-guard.sh", "timeout": 10, "statusMessage": "PII guard" },
          { "type": "command", "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/spec-tripwire.sh", "timeout": 10, "statusMessage": "Spec tripwire" },
          { "type": "command", "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/test-tripwire.sh", "timeout": 10, "statusMessage": "Test tripwire" }
        ]
      }
    ]
  }
}
