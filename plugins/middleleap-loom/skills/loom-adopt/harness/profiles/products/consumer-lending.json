{
  "profile": "consumer-lending",
  "kind": "product",
  "_comment": "Consumer (retail) lending — composes ON TOP of the base lending profile. A retail credit product automatically compiles consumer-duty, affordability, credit-risk, data and model-risk controls a wholesale product never sees.",
  "requirements": {
    "medium": {
      "approver_roles": ["conduct-risk", "credit-risk"],
      "pa1_sections": ["target-market-consumer-duty"],
      "pa2_sections": ["affordability-assessment", "responsible-lending-disclosures", "vulnerable-customer-treatment"],
      "capabilities": {
        "consumer_credit_risk": { "required": true },
        "data_risk_register": { "required": true, "minimum_version": "3.1", "institution_owned": true }
      }
    },
    "high": {
      "capabilities": {
        "model_risk": { "required": true, "minimum_tier": "high" }
      }
    }
  }
}
